    ".git",
    ".venv",
    "__pycache__",
    ".ipynb_checkpoints",
    "node_modules"
  ],
  "appendix_files": [
    "README.md",
    "final_outputs/reports/MODEL_REPORT.md",
    "final_outputs/reports/QUICK_REFERENCE.md",
    "latest_metrics.json",
    "models/manifest.json",
    "solar_power_forecasting_pipeline.py",
    "solar-prediction-vercel/app/page.tsx",
    "solar-prediction-vercel/lib/predict.ts",
    "solar-prediction-vercel/scripts/predict_with_model.py"
  ],
  "inventory_chunk_size": 70,
  "styles": {
    "university": {
      "primary_color": "#0b3a70",
      "secondary_color": "#1f4f8a",
      "table_header_color": "#0b3a70",
      "table_zebra_color": "#eef3fb",
      "title_size": 20,
      "h1_size": 14,
      "h2_size": 11,
      "body_size": 9,
      "mono_size": 7,
