{
  "metadata": {
    "title": "Solar Power Forecasting Project Report",
    "subtitle": "Comprehensive model, metrics, architecture, and deployment documentation",
    "author": "Solar Forecasting Team",
    "institution": "M.Tech Research Project",
    "footer_left": "Solar Forecasting Pipeline",
    "footer_right": "Detailed Report",
    "date_format": "%Y-%m-%d %H:%M:%S"
  },
  "paths": {
    "metrics_json": "latest_metrics.json",
    "manifest_json": "models/manifest.json",
