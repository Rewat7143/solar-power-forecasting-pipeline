      "margin_right_cm": 1.4,
      "margin_top_cm": 1.2,
      "margin_bottom_cm": 1.2
    },
    "ieee": {
      "primary_color": "#111111",
      "secondary_color": "#303030",
      "table_header_color": "#303030",
      "table_zebra_color": "#f5f5f5",
      "title_size": 18,
      "h1_size": 13,
      "h2_size": 10,
      "body_size": 8,
      "mono_size": 6,
      "margin_left_cm": 1.0,
      "margin_right_cm": 1.0,
      "margin_top_cm": 1.0,
      "margin_bottom_cm": 1.0
    }
  },
  "profiles": [
    {
      "name": "university",
      "style": "university",
      "output": "final_outputs/reports/Solar_Forecasting_Report_University.pdf",
      "metadata_overrides": {
        "footer_right": "University Style"
      }
    },
    {
      "name": "ieee",
      "style": "ieee",
      "output": "final_outputs/reports/Solar_Forecasting_Report_IEEE.pdf",
